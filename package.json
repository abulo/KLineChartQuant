{
  "name": "klinechart-monorepo",
  "version": "0.7.1",
  "description": "A lightweight financial K-line charting library with first-class AI Agent support, crisp ResizeObserver-driven rendering, and plugin-based architecture. Focused on quantitative trading scenarios with TradingView-level interaction experience.",
  "author": "363045841 <slslswbsy@qq.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/363045841/KLineChartQuant.git"
  },
  "bugs": "https://github.com/363045841/KLineChartQuant/issues",
  "homepage": "https://363045841.github.io/KLineChartQuant/",
  "keywords": [
    "kline-chart",
    "plugin-architecture",
    "webgl",
    "high-performance",
    "ai",
    "crisp-rendering",
    "sharp-rendering",
    "agent",
    "ai-chart",
    "modern-ui",
    "device-pixel-ratio",
    "candlestick-chart",
    "financial-chart",
    "tradingview",
    "canvas",
    "rendering-engine",
    "resizeobserver",
    "device-pixel-content-box",
    "drawing-tools",
    "chart-drawing",
    "trend-line",
    "fibonacci",
    "pixel-perfect",
    "responsive",
    "visualization",
    "quantitative-trading",
    "technical-analysis",
    "typescript"
  ],
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "pnpm --filter @363045841yyt/klinechart dev",
    "dev:lan": "pnpm --filter @363045841yyt/klinechart dev:lan",
    "stockbao": "cd .. && cd stockbao && uv run python ./server.py",
    "aktools": "cd .. && cd aktoolshttp && uv run python -m aktools",
    "build": "pnpm build:packages",
    "build:packages": "pnpm --filter @363045841yyt/klinechart-core build && pnpm --filter @363045841yyt/klinechart-ai-runtime build && pnpm --filter @363045841yyt/klinechart build",
    "build:demo": "vite build --config vite.demo.config.ts",
    "preview": "pnpm --filter @363045841yyt/klinechart preview",
    "preview:demo": "vite preview --config vite.demo.config.ts",
    "type-check": "vue-tsc --build",
    "test:unit": "vitest",
    "test:packages": "pnpm -r test",
    "size:packages": "pnpm -r --workspace-concurrency=4 size",
    "lint:publish": "pnpm -r --workspace-concurrency=4 lint:publish",
    "lint:types": "pnpm -r --workspace-concurrency=4 lint:types",
    "format": "prettier --write --experimental-cli packages/"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@babel/plugin-transform-typescript": "^7.29.7",
    "@iconify-json/tabler": "^1.2.34",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.8.3",
    "tsx": "^4.22.4",
    "typedoc": "^0.28.19",
    "typescript": "~6.0.3",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.16",
    "vite-plugin-babel": "^1.3.2",
    "vite-plugin-dts": "^5.0.2",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  }
}