    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@angular/common": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "@angular/core": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "@klinechart-quant/core": "workspace:*",
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "@angular/common": "^19.0.0",
    "@angular/compiler": "^19.0.0",
    "@angular/core": "^19.0.0",
    "rxjs": "^7.8.0",
    "typescript": "~5.6.0",
    "vitest": "^4.1.5",
    "zone.js": "^0.15.0"
  }
}
