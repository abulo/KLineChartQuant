{
  "name": "@klinechart-quant/core",
  "version": "0.7.2",
  "description": "Headless K-line chart engine + reactive controllers. Zero framework dependencies.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./reactivity": {
      "types": "./src/reactivity/index.ts",
      "import": "./src/reactivity/index.ts"
    },
    "./controllers": {
      "types": "./src/controllers/index.ts",
      "import": "./src/controllers/index.ts"
    },
    "./semantic": {
      "types": "./src/semantic/index.ts",
      "import": "./src/semantic/index.ts"
    },
    "./plugin": {
      "types": "./src/plugin/index.ts",
      "import": "./src/plugin/index.ts"
    },
    "./config": {
      "types": "./src/config/chartSettings.ts",
      "import": "./src/config/chartSettings.ts"
    },
    "./types/price": {
      "types": "./src/types/price.ts",
      "import": "./src/types/price.ts"
    },
    "./engine/chart": {
      "types": "./src/engine/chart.ts",
      "import": "./src/engine/chart.ts"
    },
    "./engine/chart-store": {
      "types": "./src/engine/chart-store.ts",
      "import": "./src/engine/chart-store.ts"
    },
    "./engine/utils/zoom": {
      "types": "./src/engine/utils/zoom.ts",
      "import": "./src/engine/utils/zoom.ts"
    },
    "./engine/utils/klineConfig": {
      "types": "./src/engine/utils/klineConfig.ts",
      "import": "./src/engine/utils/klineConfig.ts"
    },
    "./engine/renderers/Indicator": {
      "types": "./src/engine/renderers/Indicator/index.ts",
      "import": "./src/engine/renderers/Indicator/index.ts"
    },
    "./engine/renderers/Indicator/subPaneConfig": {
      "types": "./src/engine/renderers/Indicator/subPaneConfig.ts",
      "import": "./src/engine/renderers/Indicator/subPaneConfig.ts"
    },
    "./engine/renderers/Indicator/indicatorData": {
      "types": "./src/engine/renderers/Indicator/indicatorData.ts",
      "import": "./src/engine/renderers/Indicator/indicatorData.ts"
    },
    "./engine/renderers/paneTitle": {
      "types": "./src/engine/renderers/paneTitle.ts",
      "import": "./src/engine/renderers/paneTitle.ts"
    },
    "./engine/controller/interaction": {
      "types": "./src/engine/controller/interaction.ts",
      "import": "./src/engine/controller/interaction.ts"
    },
    "./engine/drawing": {
      "types": "./src/engine/drawing/index.ts",
      "import": "./src/engine/drawing/index.ts"
    },
    "./version": {
      "types": "./src/version.ts",
      "import": "./src/version.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "size": "size-limit",
    "lint:publish": "publint --strict .",
    "lint:types": "attw --pack ."
  },
  "size-limit": [
    {
      "name": "core (entry, pre-build src measurement)",
      "path": "src/index.ts",
      "limit": "30 KB",
      "gzip": true
    }
  ],
  "optionalDependencies": {
    "ajv": "^8.20.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/jsdom": "^28.0.0",
    "publint": "^0.3.0",
    "size-limit": "^12.1.0",
    "typescript": "~6.0.3",
    "vite-plugin-babel": "^1.3.2",
    "vitest": "^4.1.5"
  }
}