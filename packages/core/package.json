{
  "name": "@363045841yyt/klinechart-core",
  "version": "0.7.6",
  "description": "Headless K-line chart engine + reactive controllers. Zero framework dependencies.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/363045841/KLineChartQuant.git"
  },
  "bugs": "https://github.com/363045841/KLineChartQuant/issues",
  "homepage": "https://363045841.github.io/KLineChartQuant/",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./reactivity": {
      "types": "./dist/reactivity/index.d.ts",
      "import": "./dist/reactivity/index.js"
    },
    "./controllers": {
      "types": "./dist/controllers/index.d.ts",
      "import": "./dist/controllers/index.js"
    },
    "./semantic": {
      "types": "./dist/semantic/index.d.ts",
      "import": "./dist/semantic/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "import": "./dist/plugin/index.js"
    },
    "./config": {
      "types": "./dist/config/chartSettings.d.ts",
      "import": "./dist/config/chartSettings.js"
    },
    "./types/price": {
      "types": "./dist/types/price.d.ts",
      "import": "./dist/types/price.js"
    },
    "./engine/chart": {
      "types": "./dist/engine/chart.d.ts",
      "import": "./dist/engine/chart.js"
    },
    "./engine/utils/zoom": {
      "types": "./dist/engine/utils/zoom.d.ts",
      "import": "./dist/engine/utils/zoom.js"
    },
    "./engine/utils/klineConfig": {
      "types": "./dist/engine/utils/klineConfig.d.ts",
      "import": "./dist/engine/utils/klineConfig.js"
    },
    "./engine/renderers/Indicator": {
      "types": "./dist/engine/renderers/Indicator/index.d.ts",
      "import": "./dist/engine/renderers/Indicator/index.js"
    },
    "./engine/renderers/Indicator/subPaneConfig": {
      "types": "./dist/engine/renderers/Indicator/subPaneConfig.d.ts",
      "import": "./dist/engine/renderers/Indicator/subPaneConfig.js"
    },
    "./engine/renderers/Indicator/indicatorData": {
      "types": "./dist/engine/renderers/Indicator/indicatorData.d.ts",
      "import": "./dist/engine/renderers/Indicator/indicatorData.js"
    },
    "./engine/renderers/paneTitle": {
      "types": "./dist/engine/renderers/paneTitle.d.ts",
      "import": "./dist/engine/renderers/paneTitle.js"
    },
    "./engine/controller/interaction": {
      "types": "./dist/engine/controller/interaction.d.ts",
      "import": "./dist/engine/controller/interaction.js"
    },
    "./engine/marker/registry": {
      "types": "./dist/engine/marker/registry.d.ts",
      "import": "./dist/engine/marker/registry.js"
    },
    "./engine/drawing": {
      "types": "./dist/engine/drawing/index.d.ts",
      "import": "./dist/engine/drawing/index.js"
    },
    "./version": {
      "types": "./dist/version.d.ts",
      "import": "./dist/version.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "version": "node -e \"require('fs').writeFileSync('src/version.ts', 'export const VERSION = ' + JSON.stringify(require('./package.json').version) + '\\\\n')\" && git add src/version.ts",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "size": "size-limit",
    "lint:publish": "publint --strict .",
    "lint:types": "attw --pack ."
  },
  "size-limit": [
    {
      "name": "core (entry, pre-build src measurement)",
      "path": "src/index.ts",
      "limit": "30 KB",
      "gzip": true
    }
  ],
  "optionalDependencies": {
    "ajv": "^8.20.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/jsdom": "^28.0.0",
    "publint": "^0.3.0",
    "size-limit": "^12.1.0",
    "typescript": "~6.0.3",
    "vite-plugin-babel": "^1.3.2",
    "vitest": "^4.1.5"
  }
}